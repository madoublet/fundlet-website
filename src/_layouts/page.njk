---
title: Base
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Fundlet — {{ title }}</title>
  <meta name="description" content="{{ description }}{{ description | length | default('') }}{{ title }} — Fundlet Shopify fundraising app." />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800;900&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <link rel="icon" href="{{ '/resources/img/favicon.png' | url }}" />
  <link rel="stylesheet" href="{{ '/resources/css/reset.css' | url }}" />
  <link rel="stylesheet" href="{{ '/resources/css/brand.css' | url }}" />
  <link rel="stylesheet" href="{{ '/resources/css/site.css' | url }}" />
  <link rel="stylesheet" href="{{ '/resources/css/page.css' | url }}" />
</head>

<body>

{% include "header.njk" %}

<section class="page-intro">
  <div class="wrap">
    <div class="sec-head">
      <span class="eyebrow">Fundlet</span>
      <h1>{{ title }}</h1>
      {% if description %}<p class="lede">{{ description }}</p>{% endif %}
    </div>
  </div>
</section>

<div class="page-container">
  <div class="page-content">
    {{ content | safe }}
  </div>
</div>

{% include "footer.njk" %}

</body>
</html>
